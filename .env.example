# OPENAI_API_KEY: Required for OpenAI API calls.
# Set this in your environment or .env.local file.
OPENAI_API_KEY="YOUR_OPENAI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# JWT_SECRET: Secret key for signing authentication tokens.
# Change this to a strong random string in production.
JWT_SECRET="change-me-to-a-64-char-random-string-in-production"

# SERVER_PORT: Port for the Express API server.
SERVER_PORT=3001

# VITE_API_BASE: Base URL for the frontend to reach the API.
# Leave empty when using Vite proxy (recommended for local dev). The app will use /api.
# Set to http://localhost:3001/api only if calling the API directly without proxy.
VITE_API_BASE=""
